ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://professor:professor@localhost:5432/professor

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Optional overrides
ELEVENLABS_VOICE_ID=   # leave blank for default (Adam)
LLM_MODEL=             # leave blank for claude-haiku-4-5-20251001, or set claude-sonnet-4-6 for demo
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=8000
LATEX_RENDER_URL=http://localhost:3001/mathjax
